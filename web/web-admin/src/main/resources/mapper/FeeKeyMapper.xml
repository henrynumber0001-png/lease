<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nocompanyname.lease.web.admin.mapper.FeeKeyMapper">

    <select id="listFeeInfo" resultMap="feeKeyVoMap">
        SELECT
            k.id,
            k.name,
            v.id value_id,
            v.name value_name,
            v.unit,
            v.fee_key_id
        FROM
            fee_key k
        LEFT JOIN
            fee_value v ON k.id = v.fee_key_id AND v.is_deleted = 0
        WHERE
            k.is_deleted = 0
    </select>

    <resultMap id="feeKeyVoMap" type="FeeKeyVo">
        <id column = "id" property = "id"/>
        <result column = "name" property = "name"/>
        <collection property="feeValueList" ofType="FeeValue">
            <id column = "value_id" property = "id"/>
            <result column = "value_name" property = "name"/>
            <result column = "unit" property = "unit"/>
            <result column = "fee_key_id" property = "feeKeyId"/>
        </collection>
    </resultMap>

</mapper>
